:80 {
	@api {
		path /verify/* /sendEmail* /user/* /profile/* /oauth2/* /login/lark/* /login/github/*
	}
	handle @api {
		rewrite * /apis{path}
		reverse_proxy {env.BACKEND_URL}
	}

	root * /var/www
	file_server {
		index index.html
	}
	try_files {path} {path}/index.html /index.html
	encode gzip
	log {
		output stdout
		level INFO
	}
}
